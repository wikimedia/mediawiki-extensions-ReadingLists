{
	"name": "ReadingLists",
	"version": "1.0.0-beta.1",
	"author": [
		"[https://www.mediawiki.org/wiki/Readers/Reader_Experience Reader Experience Team]",
		"Bernard Wang",
		"Dillon Hardy",
		"Gergő Tisza",
		"Jon Robson",
		"Katie Filbert",
		"Loren Mora",
		"Steph Toyofuku",
		"Volker E."
	],
	"url": "https://www.mediawiki.org/wiki/Extension:ReadingLists",
	"descriptionmsg": "readinglists-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"callback": "MediaWiki\\Extension\\ReadingLists\\ExtensionRegistration::onRegistration",
	"requires": {
		"MediaWiki": ">= 1.47.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\ReadingLists\\": "src/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\ReadingLists\\Tests\\": "tests/phpunit/"
	},
	"ExtensionMessagesFiles": {
		"ReadingListsAlias": "ReadingLists.alias.php"
	},
	"APIModules": {
		"readinglists": "MediaWiki\\Extension\\ReadingLists\\Api\\ApiReadingLists"
	},
	"APIListModules": {
		"readinglistentries": {
			"class": "MediaWiki\\Extension\\ReadingLists\\Api\\ApiQueryReadingListEntries",
			"factory": "MediaWiki\\Extension\\ReadingLists\\Api\\ApiQueryReadingListEntries::factory",
			"services": [
				"ReadingLists.ReadingListRepositoryFactory",
				"ReadingLists.BookmarkEntryLookupService",
				"CentralIdLookupFactory",
				"MainConfig"
			]
		}
	},
	"APIMetaModules": {
		"readinglists": {
			"class": "MediaWiki\\Extension\\ReadingLists\\Api\\ApiQueryReadingLists",
			"factory": "MediaWiki\\Extension\\ReadingLists\\Api\\ApiQueryReadingLists::factory",
			"services": [
				"ReadingLists.ReadingListRepositoryFactory",
				"ReadingLists.BookmarkEntryLookupService",
				"CentralIdLookupFactory",
				"MainConfig"
			]
		}
	},
	"ConfigRegistry": {
		"ReadingLists": "MediaWiki\\Config\\GlobalVarConfig::newInstance"
	},
	"SpecialPages": {
		"ReadingLists": {
			"class": "MediaWiki\\Extension\\ReadingLists\\SpecialReadingLists",
			"services": [
				"MainConfig"
			]
		}
	},
	"config": {
		"ReadingListBetaFeature": {
			"value": false,
			"description": "Whether to expose reading lists as a beta feature."
		},
		"ReadingListAndroidAppDownloadLink": {
			"value": "",
			"description": "false or string representing an Android download link"
		},
		"ReadingListiOSAppDownloadLink": {
			"value": "",
			"description": "false or string representing an iOS download link"
		},
		"ReadingListsWebAuthenticatedPreviews": {
			"value": true,
			"description": "Temporary feature flag for displaying private lists."
		},
		"ReadingListsAnonymizedPreviews": {
			"value": false,
			"description": "Whether previews of shared lists should be shown."
		},
		"ReadingListsDeveloperMode": {
			"value": false,
			"description": "Enable tools that make development easier."
		},
		"ReadingListsCentralWiki": {
			"value": false,
			"description": "Database name of the central wiki. This is unrelated to data storage and only used to identify which wiki should be used for jobs and such."
		},
		"ReadingListsMaxListsPerUser": {
			"value": 100,
			"description": "Maximum allowed number of lists per user."
		},
		"ReadingListsMaxEntriesPerList": {
			"value": 1000,
			"description": "Maximum allowed number of entries per list."
		},
		"ReadingListsDeletedRetentionDays": {
			"value": 30,
			"description": "Purge deleted lists and list entries after this many days."
		},
		"ReadingListsBetaDefaultForNewAccountsAfter": {
			"value": null,
			"description": "MW timestamp in YYYYMMDDHHMMSS format (e.g. '20260301000000') after which new accounts get the ReadingLists beta feature enabled by default. Set to null to disable."
		},
		"ReadingListsEnableBetaQuickSurvey": {
			"value": false,
			"description": "Whether to enable the QuickSurvey for the ReadingLists beta feature."
		},
		"ReadingListsBloomFilterMaxItems": {
			"value": 10000,
			"description": "Maximum number of bookmarked pages to include in the bloom filter. Users exceeding this skip the filter and query the database directly."
		}
	},
	"DefaultUserOptions": {
		"readinglists-web-ui-enabled": "0"
	},
	"Hooks": {
		"CentralAuthPostLoginRedirect": "main",
		"SkinTemplateNavigation::Universal": "main",
		"GetBetaFeaturePreferences": "betafeatures",
		"GetPreferences": "main",
		"APIQuerySiteInfoGeneralInfo": "main",
		"LoadExtensionSchemaUpdates": "schema",
		"ResourceLoaderGetConfigVars": "main",
		"QuickSurveysEnabled": "main"
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\ReadingLists\\HookHandler",
			"services": [
				"MainConfig",
				"ReadingLists.ReadingListRepositoryFactory",
				"ReadingLists.BookmarkEntryLookupService",
				"UserOptionsLookup",
				"UserOptionsManager",
				"CentralIdLookupFactory",
				"UserIdentityUtils"
			],
			"optional_services": [
				"TestKitchen.ExperimentManager"
			]
		},
		"betafeatures": {
			"class": "MediaWiki\\Extension\\ReadingLists\\BetaFeatureHookHandler",
			"services": [
				"MainConfig"
			]
		},
		"schema": {
			"class": "MediaWiki\\Extension\\ReadingLists\\SchemaHookHandler"
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "ReadingLists"
	},
	"ResourceModules": {
		"ext.readingLists.special.styles": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxInfoChip"
			],
			"codexStyleOnly": true,
			"styles": [
				"resources/ext.readingLists.special/styles.less"
			]
		},
		"ext.readingLists.special.importDialog.styles": {
			"styles": [
				"resources/ext.readingLists.special.importDialog/styles.less"
			]
		},
		"ext.readingLists.api": {
			"dependencies": [
				"mediawiki.api"
			],
			"messages": [
				"readinglists-default-title",
				"readinglists-default-description"
			],
			"packageFiles": [
				"resources/ext.readingLists.api/index.js"
			]
		},
		"ext.readingLists.special": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxButton",
				"CdxCard",
				"CdxCheckbox",
				"CdxDialog",
				"CdxMessage",
				"CdxProgressBar",
				"CdxTextArea",
				"CdxToggleButton"
			],
			"dependencies": [
				"ext.readingLists.api",
				"vue"
			],
			"messages": [
				"readinglists-beta-tag",
				"readinglists-browser-error-intro",
				"readinglists-special-error-list-not-found",
				"readinglists-empty-cta",
				"readinglists-empty-title",
				"readinglists-loading",
				"readinglists-no-title",
				"readinglists-show-more",
				"readinglists-sorted-by-recent",
				"readinglists-total-articles",
				"readinglists-betafeature-quicksurvey-question",
				"readinglists-betafeature-quicksurvey-answer-positive",
				"readinglists-betafeature-quicksurvey-answer-positive-cue",
				"readinglists-betafeature-quicksurvey-answer-negative",
				"readinglists-betafeature-quicksurvey-answer-negative-cue",
				"readinglists-betafeature-quicksurvey-question-feedback",
				"readinglists-betafeature-quicksurvey-feedback-placeholder",
				"readinglists-betafeature-quicksurvey-privacy-policy",
				"readinglists-betafeature-quicksurvey-submit",
				"readinglists-betafeature-quicksurvey-thank-you"
			],
			"packageFiles": [
				"resources/ext.readingLists.special/index.js",
				"resources/ext.readingLists.special/components/EmptyList.vue",
				"resources/ext.readingLists.special/components/EntryItem.vue",
				"resources/ext.readingLists.special/components/Survey.vue",
				"resources/ext.readingLists.special/pages/Entries.vue",
				{
					"name": "icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconDie",
						"cdxIconEdit",
						"cdxIconViewCompact",
						"cdxIconViewDetails"
					]
				}
			]
		},
		"ext.readingLists.special.importDialog": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxDialog"
			],
			"dependencies": [
				"vue"
			],
			"messages": [
				"cancel",
				"readinglists-import-app",
				"readinglists-import-button-label",
				"readinglists-import-disclaimer",
				"readinglists-special-title-imported"
			],
			"packageFiles": [
				"resources/ext.readingLists.special.importDialog/components/ImportDialog.vue",
				{
					"name": "config.json",
					"config": [
						"ReadingListAndroidAppDownloadLink",
						"ReadingListiOSAppDownloadLink",
						"ReadingListsAnonymizedPreviews"
					]
				}
			]
		},
		"ext.readingLists.bookmark": {
			"packageFiles": [
				"resources/ext.readingLists.bookmark/index.js",
				"resources/ext.readingLists.bookmark/bookmark.js"
			],
			"messages": [
				"readinglists-add-bookmark",
				"readinglists-remove-bookmark",
				"readinglists-browser-add-entry-success",
				"readinglists-browser-remove-entry-success",
				"readinglists-default-title",
				"readinglists-browser-error-intro",
				"tooltip-ca-bookmark-add",
				"tooltip-ca-bookmark-remove",
				"notloggedin"
			],
			"dependencies": [
				"ext.readingLists.api",
				"ext.readingLists.bookmark.icons",
				"mediawiki.storage"
			]
		},
		"ext.readingLists.bookmark.anonymous": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxDialog"
			],
			"dependencies": [
				"mediawiki.storage",
				"vue"
			],
			"styles": [
				"resources/ext.readingLists.bookmark.anonymous/pulsatingDot.less"
			],
			"messages": [
				"readinglists-cta-dialog-title",
				"readinglists-cta-dialog-subtitle",
				"readinglists-cta-dialog-call-to-action",
				"readinglists-cta-dialog-create-account",
				"readinglists-cta-dialog-log-in",
				"readinglists-cta-dialog-close"
			],
			"packageFiles": [
				"resources/ext.readingLists.bookmark.anonymous/index.js",
				"resources/ext.readingLists.bookmark.anonymous/pulsatingDot.js",
				"resources/ext.readingLists.bookmark.anonymous/CtaDialog.vue"
			]
		},
		"ext.readingLists.bookmark.confirmPopover": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxPopover"
			],
			"dependencies": [
				"vue"
			],
			"messages": [
				"readinglists-unsave-from-custom-list-body",
				"readinglists-unsave-from-custom-list-cancel",
				"readinglists-unsave-from-custom-list-confirm",
				"readinglists-unsave-from-custom-list-title"
			],
			"packageFiles": [
				"resources/ext.readingLists.bookmark.confirmPopover/index.js",
				"resources/ext.readingLists.bookmark.confirmPopover/ConfirmUnsavePopover.vue"
			]
		},
		"ext.readingLists.bookmark.icons": {
			"class": "MediaWiki\\ResourceLoader\\OOUIIconPackModule",
			"defaultColor": "#000",
			"selectorWithVariant": ".vector-icon.mw-ui-icon-wikimedia-{name}-{variant}, .minerva-icon--{name}-{variant}",
			"selectorWithoutVariant": ".vector-icon.mw-ui-icon-wikimedia-{name}, .minerva-icon--{name}",
			"useMaskImage": true,
			"useDataURI": false,
			"icons": [
				"bookmark",
				"bookmarkOutline",
				"bookmarkList"
			]
		},
		"ext.readingLists.onboarding": {
			"dependencies": [
				"mediawiki.storage",
				"vue"
			],
			"packageFiles": [
				"resources/ext.readingLists.onboarding/index.js",
				"resources/ext.readingLists.onboarding/mountApp.js"
			]
		},
		"ext.readingLists.onboarding.desktop": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxButton",
				"CdxIcon",
				"CdxPopover"
			],
			"dependencies": [
				"ext.readingLists.onboarding"
			],
			"messages": [
				"readinglists-onboarding-title",
				"readinglists-onboarding-text",
				"readinglists-onboarding-close-button",
				"readinglists-onboarding-saved-pages-title",
				"readinglists-onboarding-saved-pages-text"
			],
			"packageFiles": [
				"resources/ext.readingLists.onboarding.desktop/index.js",
				"resources/ext.readingLists.onboarding.desktop/OnboardingPopover.vue",
				{
					"name": "icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconClose"
					]
				}
			]
		},
		"ext.readingLists.onboarding.mobile": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxPopover"
			],
			"dependencies": [
				"ext.readingLists.onboarding"
			],
			"messages": [
				"readinglists-onboarding-title",
				"readinglists-onboarding-text",
				"readinglists-onboarding-ok-button",
				"readinglists-mobile-onboarding-saved-pages-title",
				"readinglists-mobile-onboarding-saved-pages-text"
			],
			"packageFiles": [
				"resources/ext.readingLists.onboarding.mobile/index.js",
				"resources/ext.readingLists.onboarding.mobile/MobileOnboardingPopover.vue"
			]
		}
	},
	"RestModuleFiles": [
		"src/Rest/ReadingListsRoutes.v0.json"
	],
	"ServiceWiringFiles": [
		"ServiceWiring.php"
	],
	"JobClasses": {
		"buildBookmarkBloomFilter": "MediaWiki\\Extension\\ReadingLists\\Job\\BuildBloomFilterJob"
	},
	"MessagesDirs": {
		"ReadingLists": [
			"i18n",
			"i18n/api"
		]
	},
	"DatabaseVirtualDomains": [
		"virtual-readinglists"
	],
	"load_composer_autoloader": true,
	"manifest_version": 2
}
